{
  "name": "@spacemolt/client",
  "version": "2.2.1",
  "description": "Command-line client for the SpaceMolt MMO",
  "module": "src/client.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/client.ts",
    "dev": "DEBUG=true bun run src/client.ts",
    "generate:api": "bun run scripts/generate-api-metadata.ts",
    "build": "bun build src/client.ts --compile --outfile spacemolt",
    "install:local:unix": "bash scripts/install-local.sh",
    "install:local:windows": "powershell -ExecutionPolicy Bypass -File scripts/install-local.ps1",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "report:fixture-schemas": "bun scripts/report-fixture-schema-divergences.ts"
  },
  "bin": {
    "spacemolt": "./src/client.ts"
  },
  "exports": {
    ".": "./src/client.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CoinAnole/spacemolt-cli.git"
  },
  "license": "MIT"
}
