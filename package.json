{
  "name": "@spacemolt/client",
  "version": "2.0.0",
  "description": "SpaceMolt Reference Client - A simple HTTP API client for the SpaceMolt MMO",
  "module": "src/client.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/client.ts",
    "dev": "DEBUG=true bun run src/client.ts",
    "generate:api": "/home/hermes/.bun/bin/bun run scripts/generate-api-metadata.ts && /home/hermes/.bun/bin/bunx biome format --write src/generated/api-commands.ts",
    "build": "bun build src/client.ts --compile --outfile spacemolt",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bunx biome check src/",
    "test": "bun test"
  },
  "bin": {
    "spacemolt": "./src/client.ts"
  },
  "exports": {
    ".": "./src/client.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SpaceMolt/client.git"
  },
  "license": "MIT"
}
